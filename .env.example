# ──────────────────────────────────────────────────────────────────────────
# High Score Host — Sales App — environment variables
# Copy to ".env" and fill in. NEVER commit ".env". NEVER put secrets in VITE_*.
# ──────────────────────────────────────────────────────────────────────────

# ── Client (safe to ship in the browser bundle) ──
# Supabase project: cehlthclgguknjimimnw
VITE_SUPABASE_URL=https://cehlthclgguknjimimnw.supabase.co
# Dashboard > Project Settings > API keys. Use the publishable/anon key (NOT service_role).
VITE_SUPABASE_ANON_KEY=

# Top-of-funnel demo/game page for the "Demo" QR code (rep_code is appended as ?ref=).
VITE_DEMO_URL=https://example.com/demo

# ── Server only (Vercel env vars — NEVER exposed to the client) ──
# Supabase service-role key — used by the Stripe webhook to insert into `sales`.
SUPABASE_SERVICE_ROLE_KEY=
# Stripe webhook signing secret (whsec_...) from the Stripe dashboard webhook config.
STRIPE_WEBHOOK_SECRET=
# Stripe secret key (sk_...) — only needed if the webhook queries Stripe (e.g. line items).
STRIPE_SECRET_KEY=
